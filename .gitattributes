# Normalize line endings: keep LF in the repository for all text files.
* text=auto eol=lf

# Explicitly treat these as text with LF endings.
*.go    text eol=lf
*.sql   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf

# Binary artifacts.
*.exe   binary
